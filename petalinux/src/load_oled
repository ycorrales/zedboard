#!/bin/sh
### BEGIN INIT INFO
# Provides:          load_oled
# Required-Start:    $all
# Required-Stop:
# Default-Start:     5
# Default-Stop:      0 1 6
# Short-Description: Safely load and initialize ZedBoard OLED
### END INIT INFO

# Helper functions
info() { echo "[INFO]  $*"; }
ok() { echo "[OK]    $*"; }
warn() { echo "[WARN]  $*"; }
error() { echo "[ERROR] $*" >&2; }

# Put your entire core logic inside a distinct execution block
run_oled_init() {
    # Re-enable your strict exit-on-error inside this function scope if desired
    set -e

    MODULE_NAME="pmodoled_gpio"                                     # Kernel name (underscores)
    MODULE_PATH="/lib/modules/$(uname -r)/updates/pmodoled-gpio.ko" # File (hyphens)
    DEVICE_NAME="zed_oled"
    WAIT_TIME=5

    check_module() {
        if grep -q "$MODULE_NAME" /proc/modules 2>/dev/null; then
            info "$MODULE_NAME is already loaded"
            return 0
        fi

        if [ ! -f "$MODULE_PATH" ]; then
            error "Module file not found: $MODULE_PATH"
            return 1
        fi

        if [ "$(id -u)" -eq 0 ]; then
            info "Loading $MODULE_NAME from: $MODULE_PATH"
            if ! insmod "$MODULE_PATH"; then
                error "Failed to load $MODULE_NAME"
                return 1
            fi
            ok "$MODULE_NAME loaded successfully"
            info "Waiting ${WAIT_TIME}s for device creation..."
            sleep "$WAIT_TIME"
            return 0
        else
            error "Run as root to load module $MODULE_NAME!"
            return 1
        fi
    }

    if ! check_module; then
        exit 1
    fi

    # CRUCIAL FIX: Ignore sysvinit 'start' argument, default directly to binary
    if [ "$1" = "start" ] || [ -z "$1" ]; then
        BIN_PATH="/usr/share/oled/logo.bin"
    else
        BIN_PATH="$1"
    fi

    if [ ! -c "/dev/$DEVICE_NAME" ]; then
        error "/dev/$DEVICE_NAME device not found"
        exit 1
    fi

    ok "/dev/$DEVICE_NAME device verified"

    if ! [ -w "/dev/$DEVICE_NAME" ]; then
        error "Cannot write to /dev/$DEVICE_NAME (permission denied)"
        exit 1
    fi

    if [ -f "$BIN_PATH" ]; then
        FILESIZE=$(stat -c %s "$BIN_PATH" 2>/dev/null || stat -f %z "$BIN_PATH" 2>/dev/null)
        if [ "$FILESIZE" -ne 512 ]; then
            warn "Binary file size: $FILESIZE bytes (expected 512)"
        fi

        info "Loading image from: $BIN_PATH"
        if cat "$BIN_PATH" >"/dev/$DEVICE_NAME" 2>/dev/null; then
            ok "Image loaded to OLED ✓"
        else
            error "Failed to write binary to /dev/$DEVICE_NAME"
            exit 1
        fi
    else
        warn "Binary file not found: $BIN_PATH (skipping auto-load)"
    fi

    ok "Done!"
}

# SysVinit controller block
case "$1" in
start)
    # Called automatically by the system at boot
    run_oled_init "start"
    ;;
stop)
    echo "Stopping OLED service..."
    ;;
*)
    # Called manually by you from the terminal (e.g. `load_oled` or `load_oled /path/to/custom.bin`)
    run_oled_init "$1"
    ;;
esac

exit 0
